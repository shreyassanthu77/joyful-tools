{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/refs/heads/main/cli/schemas/config-file.v1.json",
  "workspace": [
    "packages/fetch",
    "packages/pipe",
    "packages/result",
    "packages/turboq"
  ],
  "nodeModulesDir": "auto",
  "exclude": ["dist/**/*"],
  "imports": {
    "@deno/graph": "jsr:@deno/graph@^0.107.1",
    "std/assert": "jsr:@std/assert",
    "std/path": "jsr:@std/path"
  },
  "tasks": {
    "test": "deno test -A",
    "build": "deno run -A scripts/build.ts",
    "bump": "deno run -A scripts/bump.ts"
  }
}
